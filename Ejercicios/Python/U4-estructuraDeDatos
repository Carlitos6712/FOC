def crear_tupla_productos(productos: list) -> tuple:
    """
    Convierte la lista de productos en una tupla.

    Las tuplas son inmutables: se usan cuando los datos no deben modificarse,
    como un catálogo de referencia. Son más eficientes en memoria que las listas.

    Args:
        productos (list): Lista de productos a convertir.

    Returns:
        tuple: Tupla con los mismos elementos que la lista.

    Example:
        >>> crear_tupla_productos(['pan', 'leche'])
        ('pan', 'leche')
    """
    return tuple(productos)


def comparar_lista_vs_tupla(lista: list, tupla: tuple) -> None:
    """
    Muestra y explica las diferencias entre lista y tupla con ejemplos concretos.

    Args:
        lista (list): Lista de productos.
        tupla (tuple): Tupla equivalente.

    Returns:
        None
    """
    print("\n  Comparativa Lista vs Tupla:")
    print(f"  {'Característica':<25} {'Lista':<15} {'Tupla'}")
    print(f"  {'-'*60}")
    print(f"  {'Tipo':<25} {str(type(lista).__name__):<15} {str(type(tupla).__name__)}")
    print(f"  {'¿Mutable?':<25} {'Sí':<15} {'No'}")
    print(f"  {'Añadir elementos':<25} {'lista.append()':<15} {'No permitido'}")
    print(f"  {'Uso recomendado':<25} {'Datos variables':<15} {'Datos fijos/constantes'}")

    print(f"\n  → Ejemplo mejor uso de tupla: coordenadas GPS, fechas, configuración.")
    print(f"  → En este caso: la tupla sería ideal para un catálogo de productos fijo.")

    # Intentamos modificar la tupla para demostrar la inmutabilidad
    try:
        tupla[0] = "nuevo_valor"  # type: ignore
    except TypeError as error:
        print(f"\n  → Intento de modificar tupla → Error esperado: {error}")


def ejecutar_ejercicio_4(productos: list) -> None:
    """
    Ejercicio 4: Crea tupla con los mismos productos y explica diferencias.

    Args:
        productos (list): Lista de productos del ejercicio anterior.

    Returns:
        None
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 4 - Tuplas vs Listas")
    print("=" * 55)

    productos_tupla = crear_tupla_productos(productos)
    print(f"\n  → Lista:  {productos}")
    print(f"  → Tupla:  {productos_tupla}")

    comparar_lista_vs_tupla(productos, productos_tupla)


