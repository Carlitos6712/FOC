# EJERCICIO 5 - Suma del 1 al 1.000.000: bucle vs sum()
# =============================================================================

def suma_con_bucle(limite: int) -> int:
    """
    Calcula la suma de todos los números del 1 al límite usando un bucle for.

    Se implementa con bucle explícito para poder comparar el rendimiento
    frente a la función built-in sum(), objetivo del ejercicio.

    Args:
        limite (int): Número hasta el que se suma (inclusive).

    Returns:
        int: Suma total de 1 + 2 + ... + limite.

    Example:
        >>> suma_con_bucle(5)
        15
    """
    total = 0
    for i in range(1, limite + 1):
        total += i
    return total


def suma_con_builtin(limite: int) -> int:
    """
    Calcula la suma de todos los números del 1 al límite usando sum().

    sum() está implementada en C internamente, por lo que es significativamente
    más rápida que un bucle Python explícito para rangos grandes.

    Args:
        limite (int): Número hasta el que se suma (inclusive).

    Returns:
        int: Suma total de 1 + 2 + ... + limite.

    Example:
        >>> suma_con_builtin(5)
        15
    """
    return sum(range(1, limite + 1))


def medir_tiempo(funcion, *args) -> tuple:
    """
    Mide el tiempo de ejecución de una función dada.

    Se usa time.time() en lugar de timeit para integrarlo de forma
    sencilla en el flujo del programa sin necesidad de módulo externo.

    Args:
        funcion (callable): La función a medir.
        *args: Argumentos que se pasarán a la función.

    Returns:
        tuple: (resultado, tiempo_en_segundos)
    """
    inicio = time.time()
    resultado = funcion(*args)
    fin = time.time()
    return resultado, fin - inicio


def ejecutar_ejercicio_5() -> None:
    """
    Ejercicio 5: Compara rendimiento entre bucle for y sum() para sumar 1 al 1.000.000.

    Returns:
        None
    """
    print("\n" + "=" * 50)
    print("  EJERCICIO 5 - Rendimiento: bucle vs sum()")
    print("=" * 50)

    limite = 1_000_000  # Guión bajo para legibilidad (PEP 515)

    resultado_bucle, tiempo_bucle = medir_tiempo(suma_con_bucle, limite)
    resultado_builtin, tiempo_builtin = medir_tiempo(suma_con_builtin, limite)

    print(f"\n  Suma 1 a {limite:,}:")
    print(f"  {'Método':<20} {'Resultado':<20} {'Tiempo (s)'}")
    print(f"  {'-'*55}")
    print(f"  {'Bucle for':<20} {resultado_bucle:<20} {tiempo_bucle:.6f}")
    print(f"  {'sum(range(...))':<20} {resultado_builtin:<20} {tiempo_builtin:.6f}")

    diferencia = tiempo_bucle / tiempo_builtin if tiempo_builtin > 0 else float("inf")
    print(f"\n  → sum() es aprox. {diferencia:.1f}x más rápido que el bucle for.")


