NOMBRE_BD = "tienda.db"


def obtener_conexion(nombre_bd: str = NOMBRE_BD) -> sqlite3.Connection:
    """
    Crea y devuelve una conexión a la base de datos SQLite.

    Se centraliza la conexión aquí para que todos los métodos CRUD
    usen el mismo punto de acceso y sea fácil cambiar la BD en el futuro.

    Args:
        nombre_bd (str): Ruta o nombre del archivo de base de datos.

    Returns:
        sqlite3.Connection: Objeto de conexión activa.
    """
    return sqlite3.connect(nombre_bd)


def crear_tabla_productos(conexion: sqlite3.Connection) -> None:
    """
    Crea la tabla 'productos' en la base de datos si no existe.

    Usa IF NOT EXISTS para que el script sea idempotente:
    se puede ejecutar múltiples veces sin error ni duplicados.

    Esquema de la tabla:
        - id: INTEGER PRIMARY KEY (autoincremento)
        - nombre: TEXT NOT NULL
        - precio: REAL (precio con decimales)
        - tipo: TEXT (categoría del producto)
        - fecha_caducidad: TEXT (almacenada como ISO 8601: YYYY-MM-DD)

    Args:
        conexion (sqlite3.Connection): Conexión activa a SQLite.

    Returns:
        None
    """
    cursor = conexion.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS productos (
            id               INTEGER PRIMARY KEY,
            nombre           TEXT    NOT NULL,
            precio           REAL,
            tipo             TEXT,
            fecha_caducidad  TEXT
        )
    """)
    conexion.commit()
    print("  → Tabla 'productos' creada o ya existente (IF NOT EXISTS).")


def ejecutar_ejercicio_4() -> sqlite3.Connection:
    """
    Ejercicio 4: Conecta a SQLite y crea la tabla productos.

    Returns:
        sqlite3.Connection: Conexión abierta para reutilizar en ejercicio 5.
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 4 - Conexión SQLite y tabla productos")
    print("=" * 55)

    conexion = obtener_conexion()
    crear_tabla_productos(conexion)
    print(f"  → Conectado a: {NOMBRE_BD}")

    return conexion


