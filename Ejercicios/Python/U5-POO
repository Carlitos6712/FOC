# EJERCICIO 1 - Clase Producto (POO básica)
# =============================================================================

class Producto:
    """
    Representa un artículo de una tienda con id, nombre y precio.

    Aplica encapsulamiento básico: los atributos son públicos en este nivel
    y se vuelven privados con getter/setter en ProductoAlimenticio (Ej. 2).

    Attributes:
        id (int): Identificador único del producto.
        nombre (str): Nombre descriptivo del producto.
        precio (float): Precio en euros del producto.

    Example:
        >>> p = Producto(1, 'Manzana', 1.20)
        >>> p.mostrar_info()
        ID: 1 | Nombre: Manzana | Precio: 1.20 €
    """

    def __init__(self, id: int, nombre: str, precio: float) -> None:
        """
        Constructor de Producto.

        Args:
            id (int): Identificador del producto.
            nombre (str): Nombre del producto.
            precio (float): Precio del producto (debe ser >= 0).

        Raises:
            ValueError: Si el precio es negativo.
        """
        if precio < 0:
            raise ValueError(f"El precio no puede ser negativo: {precio}")

        self.id = id
        self.nombre = nombre
        self.precio = precio

    def mostrar_info(self) -> None:
        """
        Muestra la información del producto por pantalla.

        Returns:
            None
        """
        print(f"  ID: {self.id} | Nombre: {self.nombre:<20} | Precio: {self.precio:.2f} €")

    def __repr__(self) -> str:
        """
        Representación técnica del objeto para depuración.

        Returns:
            str: Representación del objeto.
        """
        return f"Producto(id={self.id}, nombre='{self.nombre}', precio={self.precio})"


