# EJERCICIO 1 - Lista de productos: crear, mostrar, añadir
# =============================================================================

def crear_lista_productos() -> list:
    """
    Crea y devuelve una lista con al menos 5 nombres de productos.

    Los productos se definen aquí como datos de muestra para que el ejercicio
    sea autoejecutable sin necesidad de entrada manual.

    Returns:
        list: Lista de strings con nombres de productos.

    Example:
        >>> crear_lista_productos()
        ['manzana', 'leche', 'pan', 'arroz', 'aceite']
    """
    return ["manzana", "leche", "pan", "arroz", "aceite"]


def mostrar_lista(productos: list) -> None:
    """
    Muestra todos los elementos de la lista por pantalla con su índice.

    Args:
        productos (list): Lista de productos a mostrar.

    Returns:
        None
    """
    print("\n  Lista de productos:")
    for indice, producto in enumerate(productos):
        print(f"    [{indice}] {producto}")


def mostrar_primero_y_ultimo(productos: list) -> None:
    """
    Muestra el primer y último elemento de una lista.

    Usa índice -1 para acceder al último elemento (idiomático en Python),
    evitando calcular len() - 1.

    Args:
        productos (list): Lista de la que se extraen los extremos.

    Returns:
        None

    Raises:
        IndexError: Si la lista está vacía.
    """
    if not productos:
        print("  ✗ La lista está vacía.")
        return

    print(f"\n  → Primero: {productos[0]}")
    print(f"  → Último:  {productos[-1]}")


def aniadir_producto(productos: list, nuevo_producto: str) -> list:
    """
    Añade un nuevo producto al final de la lista usando append().

    append() modifica la lista en sitio (in-place) y es O(1) amortizado,
    la opción más eficiente para añadir al final.

    Args:
        productos (list): Lista original de productos.
        nuevo_producto (str): Nombre del producto a añadir.

    Returns:
        list: La misma lista con el producto añadido.

    Example:
        >>> aniadir_producto(['pan', 'leche'], 'huevos')
        ['pan', 'leche', 'huevos']
    """
    productos.append(nuevo_producto)
    return productos


def ejecutar_ejercicio_1() -> list:
    """
    Ejercicio 1: Crea lista, muestra completa, primero/último, añade elemento.

    Returns:
        list: Lista actualizada (se reutiliza en ejercicio 2).
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 1 - Lista de productos")
    print("=" * 55)

    productos = crear_lista_productos()
    mostrar_lista(productos)
    mostrar_primero_y_ultimo(productos)

    nuevo = "yogur"
    aniadir_producto(productos, nuevo)
    print(f"\n  → Producto '{nuevo}' añadido con append().")
    mostrar_lista(productos)

    return productos


# =============================================================================
# EJERCICIO 2 - Ordenar y eliminar de la lista
# =============================================================================

def ordenar_lista_alfabeticamente(productos: list) -> list:
    """
    Ordena la lista de productos alfabéticamente y la devuelve.

    Usa sorted() en lugar de .sort() para generar una nueva lista ordenada
    sin modificar la original, respetando la inmutabilidad cuando sea posible.

    Args:
        productos (list): Lista de productos a ordenar.

    Returns:
        list: Nueva lista ordenada alfabéticamente.

    Example:
        >>> ordenar_lista_alfabeticamente(['pan', 'arroz', 'leche'])
        ['arroz', 'leche', 'pan']
    """
    return sorted(productos)


def eliminar_producto(productos: list, producto: str) -> list:
    """
    Elimina un producto concreto de la lista si existe.

    Se comprueba existencia con 'in' antes de remove() para evitar
    ValueError en caso de que el producto no esté en la lista.

    Args:
        productos (list): Lista de productos.
        producto (str): Nombre del producto a eliminar.

    Returns:
        list: Lista actualizada tras la eliminación.

    Example:
        >>> eliminar_producto(['pan', 'leche', 'arroz'], 'leche')
        ['pan', 'arroz']
    """
    if producto in productos:
        productos.remove(producto)
        print(f"  → Producto '{producto}' eliminado correctamente.")
    else:
        print(f"  ✗ Producto '{producto}' no encontrado en la lista.")
    return productos


def ejecutar_ejercicio_2(productos: list) -> list:
    """
    Ejercicio 2: Ordena alfabéticamente y elimina un producto concreto.

    Args:
        productos (list): Lista generada en el ejercicio 1.

    Returns:
        list: Lista resultante tras operaciones.
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 2 - Ordenar y eliminar")
    print("=" * 55)

    ordenada = ordenar_lista_alfabeticamente(productos)
    print("\n  → Lista ordenada alfabéticamente:")
    mostrar_lista(ordenada)

    producto_a_eliminar = "arroz"
    eliminar_producto(ordenada, producto_a_eliminar)
    print("\n  → Lista actualizada tras eliminación:")
    mostrar_lista(ordenada)

    return ordenada


