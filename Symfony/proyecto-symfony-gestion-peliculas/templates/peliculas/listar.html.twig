{# templates/peliculas/listar.html.twig #}
{# @author Carlos Vico #}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Listado de Películas</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; background: #f0f0f0; padding: 40px 20px; }
        .container { max-width: 900px; margin: 0 auto; background: white; border-radius: 8px; padding: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        h1 { color: #222; margin-bottom: 24px; border-bottom: 3px solid #222; padding-bottom: 12px; }
        table { width: 100%; border-collapse: collapse; }
        thead th { background: #222; color: white; padding: 12px 16px; text-align: left; font-size: 14px; }
        tbody td { padding: 12px 16px; border-bottom: 1px solid #eee; font-size: 14px; }
        tbody tr:hover { background: #f9f9f9; }
        .btn { display: inline-block; padding: 6px 14px; background: #222; color: white; border-radius: 4px; text-decoration: none; font-size: 13px; }
        .btn:hover { background: #444; }
        .empty { color: #999; font-style: italic; margin-top: 16px; }
        .actions { margin-top: 24px; }
        .btn-insert { background: #2e7d32; }
        .btn-insert:hover { background: #388e3c; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎬 Gestión de Películas</h1>

        <div class="actions">
            <a class="btn btn-insert" href="/pelicula/insertar">+ Insertar película de ejemplo</a>
        </div>

        {% if peliculas is empty %}
            <p class="empty">No hay películas en la base de datos. Inserta una para comenzar.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Título</th>
                        <th>Director</th>
                        <th>Año</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {# Iteramos el array de objetos Pelicula pasado desde el controlador #}
                    {% for pelicula in peliculas %}
                        <tr>
                            <td>{{ pelicula.id }}</td>
                            <td>{{ pelicula.titulo }}</td>
                            <td>{{ pelicula.director }}</td>
                            <td>{{ pelicula.anyo }}</td>
                            <td><a class="btn" href="/pelicula/{{ pelicula.id }}">Ver detalle</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</body>
</html>
