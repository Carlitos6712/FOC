    try:
        # Input convertido a float (el original no lo hacía)
        base = float(input("Introduce la base:    "))
        altura = float(input("Introduce la altura:  "))
        resultado = area_rectangulo(base, altura)
        # f-string correcta (el original tenía concatenación rota)
        print(f"\n  → El área es: {resultado}")
    except ValueError as error:
        print(f"  ✗ Error de valor: {error}")


