# EJERCICIO 2 - Encapsulamiento con getter/setter
# =============================================================================

class ProductoConPrecioPrivado(Producto):
    """
    Extiende Producto con precio privado y validación via getter/setter.

    El atributo __precio usa name mangling de Python (doble guión bajo)
    para garantizar que no se modifique directamente desde fuera de la clase,
    obligando a pasar por el setter que aplica la validación.

    Hereda de:
        Producto

    Example:
        >>> p = ProductoConPrecioPrivado(1, 'Pan', 1.50)
        >>> p.precio = -5
        ValueError: El precio no puede ser negativo.
        >>> p.precio = 2.00
        >>> print(p.precio)
        2.0
    """

    def __init__(self, id: int, nombre: str, precio: float) -> None:
        """
        Constructor que inicializa el precio a través del setter.

        Args:
            id (int): Identificador del producto.
            nombre (str): Nombre del producto.
            precio (float): Precio inicial (validado por el setter).
        """
        # Llamamos al padre sin precio para luego asignarlo por el setter
        self.id = id
        self.nombre = nombre
        self.precio = precio  # Invoca el setter definido abajo

    @property
    def precio(self) -> float:
        """
        Getter del precio privado.

        Returns:
            float: Precio actual del producto.
        """
        return self.__precio

    @precio.setter
    def precio(self, nuevo_precio: float) -> None:
        """
        Setter del precio con validación de valor no negativo.

        Se usa setter en lugar de validación en __init__ para que la regla
        de negocio se aplique también cuando el precio se modifica después
        de la creación del objeto.

        Args:
            nuevo_precio (float): Nuevo precio a asignar.

        Raises:
            ValueError: Si el precio es negativo.
        """
        if nuevo_precio < 0:
            raise ValueError(f"El precio no puede ser negativo: {nuevo_precio}")
        # Doble guión bajo → name mangling: _ProductoConPrecioPrivado__precio
        self.__precio = nuevo_precio


def ejecutar_ejercicio_2() -> None:
    """
