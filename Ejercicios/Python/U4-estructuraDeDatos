def crear_diccionario_stock(productos: list) -> dict:
    """
    Crea un diccionario de stock a partir de la lista de productos.

    Las claves son los nombres de los productos (strings) y los valores
    son enteros que representan la cantidad disponible.
    Se asignan valores de ejemplo para simular un inventario real.

    Args:
        productos (list): Lista de nombres de productos.

    Returns:
        dict: Diccionario {nombre_producto: cantidad}.

    Example:
        >>> crear_diccionario_stock(['pan', 'leche'])
        {'pan': 15, 'leche': 8}
    """
    # Cantidades de ejemplo representativas para cada producto
    cantidades_ejemplo = [15, 8, 22, 5, 30, 12]

    # zip() combina producto con su cantidad; si hay más productos que cantidades,
    # se asigna 0 como valor por defecto
    stock = {}
    for indice, producto in enumerate(productos):
        stock[producto] = cantidades_ejemplo[indice] if indice < len(cantidades_ejemplo) else 0

    return stock


def calcular_total_productos(stock: dict) -> int:
    """
    Calcula la suma total de todos los valores (cantidades) del diccionario.

    Usa sum() con values() que es la forma más idiomática y eficiente en Python
    para sumar todos los valores de un diccionario.

    Args:
        stock (dict): Diccionario de stock {producto: cantidad}.

    Returns:
        int: Suma total de todas las cantidades.

    Example:
        >>> calcular_total_productos({'pan': 10, 'leche': 5})
        15
    """
    return sum(stock.values())


def productos_con_stock_minimo(stock: dict, minimo: int) -> list:
    """
    Devuelve los productos cuyo stock supera una cantidad dada.

    La comprensión de lista es más legible y eficiente que un bucle
    for con append() para este tipo de filtrado.

    Args:
        stock (dict): Diccionario {producto: cantidad}.
        minimo (int): Umbral mínimo de stock (exclusive).

    Returns:
        list: Lista de productos con cantidad > minimo.

    Example:
        >>> productos_con_stock_minimo({'pan': 15, 'leche': 5}, 10)
        ['pan']
    """
    return [producto for producto, cantidad in stock.items() if cantidad > minimo]


def ejecutar_ejercicio_3(productos: list) -> dict:
    """
    Ejercicio 3: Crea diccionario de stock y aplica funciones de análisis.

    Args:
        productos (list): Lista de productos del ejercicio anterior.

    Returns:
        dict: Diccionario de stock creado.
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 3 - Diccionario de stock")
    print("=" * 55)

    stock = crear_diccionario_stock(productos)

    print("\n  → Stock actual:")
    for producto, cantidad in stock.items():
        print(f"    {producto:<15} : {cantidad} unidades")

    total = calcular_total_productos(stock)
    print(f"\n  → Total de productos disponibles: {total}")

    umbral = 10
    con_stock_alto = productos_con_stock_minimo(stock, umbral)
    print(f"\n  → Productos con más de {umbral} unidades: {con_stock_alto}")

    return stock


