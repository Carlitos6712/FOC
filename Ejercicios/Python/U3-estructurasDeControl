OPERACIONES_VALIDAS = ("+", "-", "*", "/")


def solicitar_operacion() -> str:
    """
    Solicita al usuario una operación aritmética válida.

    Valida que la operación sea una de las permitidas (+, -, *, /)
    para evitar procesar operadores no soportados.

    Returns:
        str: Operador aritmético válido.

    Example:
        >>> solicitar_operacion()
        Operación (+, -, *, /): +
        '+'
    """
    while True:
        op = input(f"Operación {OPERACIONES_VALIDAS}: ").strip()
        if op in OPERACIONES_VALIDAS:
            return op
        print(f"  ✗ Operación '{op}' no válida. Elige entre: {OPERACIONES_VALIDAS}")


def calcular(a: float, b: float, operacion: str) -> float | None:
    """
    Realiza una operación aritmética entre dos números.

    La división por cero se gestiona explícitamente para devolver None
    en lugar de lanzar ZeroDivisionError, manteniendo el control en el llamador.

    Args:
        a (float): Operando izquierdo.
        b (float): Operando derecho.
        operacion (str): Operador aritmético (+, -, *, /).

    Returns:
        float | None: Resultado de la operación, o None si hay división por cero.

    Example:
        >>> calcular(10, 2, '/')
        5.0
        >>> calcular(10, 0, '/')
        None
    """
    if operacion == "+":
        return a + b
    elif operacion == "-":
        return a - b
    elif operacion == "*":
        return a * b
    elif operacion == "/":
        if b == 0:
            # Devolvemos None en lugar de lanzar excepción para control limpio
            print("  ✗ Error: División por cero no permitida.")
            return None
        return a / b


def ejecutar_ejercicio_3() -> None:
