def crear_almacen() -> dict:
    """
    Crea un diccionario anidado representando un almacén con productos.

    Cada clave es el nombre del producto, y el valor es otro diccionario
    con las propiedades: nombre, precio y stock.

    Se usa estructura anidada para reflejar un modelo de datos real
    donde cada entidad tiene múltiples atributos.

    Returns:
        dict: Diccionario anidado {nombre_producto: {nombre, precio, stock}}.

    Example:
        >>> almacen = crear_almacen()
        >>> almacen['manzana']['precio']
        1.2
    """
    return {
        "manzana":  {"nombre": "Manzana",   "precio": 1.20,  "stock": 50},
        "leche":    {"nombre": "Leche",      "precio": 0.99,  "stock": 30},
        "pan":      {"nombre": "Pan",        "precio": 1.50,  "stock": 20},
        "arroz":    {"nombre": "Arroz",      "precio": 2.10,  "stock": 15},
        "aceite":   {"nombre": "Aceite",     "precio": 4.75,  "stock": 8},
    }


def mostrar_precio_producto(almacen: dict, nombre_producto: str) -> None:
    """
    Muestra el precio de un producto concreto del almacén.

    Args:
        almacen (dict): Diccionario del almacén.
        nombre_producto (str): Clave del producto a consultar.

    Returns:
        None
    """
    producto = almacen.get(nombre_producto)
    if producto:
        print(f"  → Precio de '{producto['nombre']}': {producto['precio']:.2f} €")
    else:
        print(f"  ✗ Producto '{nombre_producto}' no encontrado en el almacén.")


def mostrar_productos_con_stock_inferior(almacen: dict, limite: int) -> None:
    """
    Muestra todos los productos cuyo stock es inferior al límite dado.

    Args:
        almacen (dict): Diccionario del almacén.
        limite (int): Umbral de stock (exclusive).

    Returns:
        None
    """
    print(f"\n  → Productos con stock inferior a {limite}:")
    encontrados = False

    for clave, datos in almacen.items():
        if datos["stock"] < limite:
            print(f"    - {datos['nombre']}: {datos['stock']} unidades")
            encontrados = True

    if not encontrados:
        print(f"    (Ningún producto tiene stock inferior a {limite})")


def calcular_valor_total_almacen(almacen: dict) -> float:
    """
    Calcula el valor total del inventario (precio × stock de cada producto).

    El valor total representa la inversión total en stock del almacén,
    un dato clave para contabilidad e inventario.

    Args:
        almacen (dict): Diccionario del almacén con precio y stock.

    Returns:
        float: Suma de (precio * stock) para todos los productos.

    Example:
        >>> almacen = {'pan': {'precio': 1.5, 'stock': 10}}
        >>> calcular_valor_total_almacen(almacen)
        15.0
    """
    return sum(datos["precio"] * datos["stock"] for datos in almacen.values())


def ejecutar_ejercicio_5() -> None:
    """
    Ejercicio 5: Crea almacén anidado, consulta precio, filtra stock y calcula valor total.

    Returns:
        None
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 5 - Diccionario anidado de almacén")
    print("=" * 55)

    almacen = crear_almacen()

    # Mostrar estructura completa del almacén
    print("\n  → Almacén completo:")
    print(f"  {'Producto':<15} {'Precio':>8} {'Stock':>8}")
    print(f"  {'-'*35}")
    for datos in almacen.values():
        print(f"  {datos['nombre']:<15} {datos['precio']:>7.2f}€ {datos['stock']:>7}")

    # Precio de un producto concreto
    print()
    mostrar_precio_producto(almacen, "aceite")

    # Productos con stock bajo
    mostrar_productos_con_stock_inferior(almacen, 20)

    # Valor total del almacén
    valor_total = calcular_valor_total_almacen(almacen)
    print(f"\n  → Valor total del inventario: {valor_total:.2f} €")


