def area_rectangulo(base: float, altura: float) -> float:
    """
    Calcula el área de un rectángulo.

    Correcciones aplicadas al código original con errores:
      1. El nombre de la función era 'area_rectangulo(base, altura)' sin tipo de retorno
         y sin validación de parámetros.
      2. 'area = base * altura' → correcto (no 'base ** altura' que elevaría a potencia).
      3. Faltaba el 'return area' dentro de la función (estaba fuera con indentación errónea).
      4. El input no convertía a float, causando TypeError al multiplicar strings.
      5. La cadena del print tenía error de concatenación (usaba 'as' en lugar de '=').

    Args:
        base (float): La base del rectángulo (debe ser positiva).
        altura (float): La altura del rectángulo (debe ser positiva).

    Returns:
        float: El área resultante (base × altura).

    Raises:
        ValueError: Si base o altura son valores negativos o cero.

    Example:
        >>> area_rectangulo(5, 3)
        15.0
    """
    if base <= 0 or altura <= 0:
        raise ValueError("La base y la altura deben ser valores positivos.")

    # Multiplicación, NO potencia (**): el código original usaba base ** altura
    area = base * altura
    return area  # Return DENTRO de la función, no fuera


def ejecutar_ejercicio_4() -> None:
    """
    Ejercicio 4: Versión corregida del código con errores de área de rectángulo.

    Returns:
