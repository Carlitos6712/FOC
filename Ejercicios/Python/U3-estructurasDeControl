def mostrar_positivos_hasta(limite: int) -> None:
    """
    Muestra todos los números desde 1 hasta `limite` si este es positivo.

    Si el límite no es positivo, informa al usuario sin lanzar excepción,
    ya que es un caso de uso válido pero sin resultado útil.

    Usa for porque el rango es conocido de antemano (iteración determinista).

    Args:
        limite (int): Número hasta el que se mostrará la secuencia (inclusive).

    Returns:
        None

    Example:
        >>> mostrar_positivos_hasta(5)
        1 2 3 4 5
    """
    if limite <= 0:
        print(f"  ✗ El número {limite} no es positivo. No hay valores que mostrar.")
        return

    # Usamos end=" " para mostrar en línea y ahorrar espacio en consola
    for i in range(1, limite + 1):
        print(i, end=" ")
    print()  # Salto de línea al finalizar


