def solicitar_entero(mensaje: str) -> int:
    """
    Solicita un número entero al usuario con validación de entrada.

    Reutilizable en todos los ejercicios que requieran entrada numérica entera.

    Args:
        mensaje (str): Texto que se muestra al usuario al pedir el dato.

    Returns:
        int: Número entero válido introducido por el usuario.

    Example:
        >>> solicitar_entero("Introduce el primer número: ")
        Introduce el primer número: 5
        5
    """
    while True:
        entrada = input(mensaje)
        try:
            return int(entrada)
        except ValueError:
            print(f"  ✗ '{entrada}' no es válido. Introduce un número entero.")


def encontrar_mayor(a: int, b: int, c: int) -> int:
    """
    Determina el mayor entre tres números enteros usando if/elif/else.

    Se usa if/elif/else múltiple (no max()) porque el enunciado exige
    explícitamente el uso de condicionales múltiples.

    Args:
        a (int): Primer número.
        b (int): Segundo número.
        c (int): Tercer número.

    Returns:
        int: El valor más alto de los tres.

    Example:
        >>> encontrar_mayor(3, 7, 5)
        7
        >>> encontrar_mayor(10, 10, 5)
        10
    """
    if a >= b and a >= c:
        return a
    elif b >= a and b >= c:
        return b
    else:
        return c


def ejecutar_ejercicio_1() -> None:
    """
    Ejercicio 1: Solicita tres números y muestra el mayor.

    Returns:
        None
    """
    print("\n" + "=" * 50)
    print("  EJERCICIO 1 - Mayor de tres números")
    print("=" * 50)

    a = solicitar_entero("Introduce el primer número:  ")
    b = solicitar_entero("Introduce el segundo número: ")
    c = solicitar_entero("Introduce el tercer número:  ")

    mayor = encontrar_mayor(a, b, c)
    print(f"\n  → El mayor de {a}, {b} y {c} es: {mayor}")


