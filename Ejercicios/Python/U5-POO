# EJERCICIO 3 - Herencia: ProductoAlimenticio
# =============================================================================

class ProductoAlimenticio(ProductoConPrecioPrivado):
    """
    Extiende ProductoConPrecioPrivado añadiendo fecha de caducidad.

    Hereda toda la lógica de precio encapsulado e incorpora
    la comprobación de caducidad como nueva responsabilidad de esta subclase.

    Hereda de:
        ProductoConPrecioPrivado

    Attributes:
        fecha_caducidad (date): Fecha límite de consumo del producto.

    Example:
        >>> from datetime import date
        >>> p = ProductoAlimenticio(1, 'Yogur', 0.80, date(2025, 12, 31))
        >>> p.esta_caducado()
        False
    """

    def __init__(self, id: int, nombre: str, precio: float, fecha_caducidad: date) -> None:
        """
        Constructor de ProductoAlimenticio.

        Args:
            id (int): Identificador del producto.
            nombre (str): Nombre del producto.
            precio (float): Precio del producto.
            fecha_caducidad (date): Fecha de caducidad del producto.
        """
        super().__init__(id, nombre, precio)
        self.fecha_caducidad = fecha_caducidad

    def esta_caducado(self) -> bool:
        """
        Comprueba si el producto está caducado en función de la fecha actual.

        Compara con date.today() para tener siempre la fecha real,
        sin necesidad de pasar la fecha como parámetro.

        Returns:
            bool: True si la fecha de caducidad ya pasó, False en caso contrario.

        Example:
            >>> p = ProductoAlimenticio(1, 'Leche', 0.99, date(2020, 1, 1))
            >>> p.esta_caducado()
            True
        """
        return self.fecha_caducidad < date.today()

    def mostrar_info(self) -> None:
        """
        Extiende mostrar_info() del padre añadiendo caducidad.

        Returns:
            None
        """
        super().mostrar_info()
        estado = "⚠ CADUCADO" if self.esta_caducado() else "✔ En fecha"
        print(f"    Caducidad: {self.fecha_caducidad} | Estado: {estado}")


