# EJERCICIO 5 - CRUD en base de datos desde clase gestora
# =============================================================================

class GestorBD:
    """
    Gestiona todas las operaciones CRUD sobre la tabla productos en SQLite.

    Centraliza la lógica de base de datos para que las clases Producto
    no tengan dependencia directa con la capa de persistencia (SRP).

    Attributes:
        conexion (sqlite3.Connection): Conexión activa a la base de datos.

    Example:
        >>> gestor = GestorBD(conexion)
        >>> gestor.insertar_producto(ProductoAlimenticio(1, 'Pan', 1.5, date(2026, 1, 1)))
    """

    def __init__(self, conexion: sqlite3.Connection) -> None:
        """
        Constructor del gestor de base de datos.

        Args:
            conexion (sqlite3.Connection): Conexión activa a SQLite.
        """
        # Guardamos la conexión existente en lugar de crear una nueva
        # para que toda la sesión comparta el mismo contexto transaccional
        self.conexion = conexion

    def insertar_producto(self, producto: ProductoAlimenticio) -> None:
        """
        Inserta un objeto ProductoAlimenticio en la tabla productos.

        Usa parámetros nombrados (?) para evitar inyección SQL.

        Args:
            producto (ProductoAlimenticio): El objeto a persistir.

        Returns:
            None
        """
        cursor = self.conexion.cursor()
        cursor.execute(
            "INSERT INTO productos (nombre, precio, tipo, fecha_caducidad) VALUES (?, ?, ?, ?)",
            (
                producto.nombre,
                producto.precio,
                "Alimenticio",
                str(producto.fecha_caducidad),
            )
        )
        self.conexion.commit()
        print(f"  → Producto '{producto.nombre}' insertado en la BD.")

    def obtener_todos_los_productos(self) -> list:
        """
        Recupera todos los registros de la tabla productos.

        Returns:
            list: Lista de tuplas con todos los registros (id, nombre, precio, tipo, fecha).
        """
        cursor = self.conexion.cursor()
        cursor.execute("SELECT * FROM productos")
        return cursor.fetchall()

    def mostrar_todos_los_productos(self) -> None:
        """
        Obtiene y muestra por pantalla todos los productos de la base de datos.

        Returns:
            None
        """
        registros = self.obtener_todos_los_productos()

        if not registros:
            print("  → No hay productos en la base de datos.")
            return

        print(f"\n  {'ID':<5} {'Nombre':<20} {'Precio':>8} {'Tipo':<15} {'Caducidad'}")
        print(f"  {'-'*65}")
        for fila in registros:
            id_prod, nombre, precio, tipo, caducidad = fila
            print(f"  {id_prod:<5} {nombre:<20} {precio:>7.2f}€ {str(tipo):<15} {caducidad}")


def ejecutar_ejercicio_5(conexion: sqlite3.Connection) -> None:
    """
    Ejercicio 5: Inserta productos alimenticios y muestra todos los registros.

    Args:
        conexion (sqlite3.Connection): Conexión abierta desde el ejercicio 4.

    Returns:
        None
    """
    print("\n" + "=" * 55)
    print("  EJERCICIO 5 - CRUD desde GestorBD")
    print("=" * 55)

    gestor = GestorBD(conexion)

    productos_a_insertar = [
        ProductoAlimenticio(None, "Manzana", 1.20, date(2026, 6, 30)),
        ProductoAlimenticio(None, "Leche",   0.99, date(2026, 2, 15)),
        ProductoAlimenticio(None, "Yogur",   0.80, date(2026, 8, 10)),
    ]

    print("\n  → Insertando productos:")
    for producto in productos_a_insertar:
        gestor.insertar_producto(producto)

    print("\n  → Lista completa de la tabla productos:")
    gestor.mostrar_todos_los_productos()

    # Cerramos la conexión cuando ya no se necesita
    conexion.close()
    print("\n  → Conexión a la base de datos cerrada.")


